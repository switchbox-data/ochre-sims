{
	"name": "ochre-sims",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"RandomFractalsInc.duckdb-sql-tools",
